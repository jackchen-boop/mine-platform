.search-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.search-input {
  flex: 1;
  background: #1a1a26;
  border: 1rpx solid #2a2a3a;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #e2e8f0;
  font-size: 28rpx;
}

.search-btn {
  background: linear-gradient(135deg, #c9a96e, #e0c88a);
  color: #0a0a0f;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.filter-scroll {
  margin-bottom: 24rpx;
  white-space: nowrap;
}

.filter-tags {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.filter-tag {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid #2a2a3a;
  background: #12121a;
  color: #94a3b8;
  font-size: 26rpx;
}

.filter-tag.active {
  background: rgba(201, 169, 110, 0.15);
  border-color: #c9a96e;
  color: #c9a96e;
}

.project-list {
  padding-bottom: 40rpx;
}

.project-card {
  background: #12121a;
  border: 1rpx solid #2a2a3a;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.project-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #e2e8f0;
  flex: 1;
}

.project-tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-gold {
  background: rgba(201, 169, 110, 0.1);
  color: #c9a96e;
  border: 1rpx solid rgba(201, 169, 110, 0.2);
}

.tag-gray {
  background: #1a1a26;
  color: #94a3b8;
  border: 1rpx solid #2a2a3a;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
}

.info-label {
  color: #64748b;
  font-size: 26rpx;
  width: 100rpx;
}

.info-value {
  color: #e2e8f0;
  font-size: 26rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  color: #64748b;
  font-size: 28rpx;
}
