page {
  background-color: #0a0a0f;
  color: #e2e8f0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 20rpx 30rpx;
}

/* 卡片样式 */
.card {
  background: #12121a;
  border: 1rpx solid #2a2a3a;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

/* 金色主题色 */
.text-gold {
  color: #c9a96e;
}

.bg-gold {
  background-color: #c9a96e;
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #c9a96e, #e0c88a);
  color: #0a0a0f;
  border-radius: 24rpx;
  font-weight: 600;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-outline {
  background: transparent;
  border: 1rpx solid #c9a96e;
  color: #c9a96e;
  border-radius: 24rpx;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
}

/* 输入框 */
.input-field {
  background: #1a1a26;
  border: 1rpx solid #2a2a3a;
  border-radius: 16rpx;
  padding: 24rpx;
  color: #e2e8f0;
  font-size: 28rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-gold {
  background: rgba(201, 169, 110, 0.1);
  color: #c9a96e;
  border: 1rpx solid rgba(201, 169, 110, 0.2);
}

.tag-gray {
  background: #1a1a26;
  color: #94a3b8;
  border: 1rpx solid #2a2a3a;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #2a2a3a;
  margin: 20rpx 0;
}
