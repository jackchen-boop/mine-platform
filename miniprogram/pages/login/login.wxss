.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 60rpx;
}

.logo-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.logo-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.logo-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #c9a96e;
}

.logo-subtitle {
  font-size: 28rpx;
  color: #64748b;
  margin-top: 8rpx;
}

.login-form {
  width: 100%;
}

.form-group {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #94a3b8;
  margin-bottom: 12rpx;
}

.input-field {
  background: #1a1a26;
  border: 1rpx solid #2a2a3a;
  border-radius: 16rpx;
  padding: 28rpx;
  color: #e2e8f0;
  font-size: 28rpx;
}

.error-msg {
  color: #ef4444;
  font-size: 24rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.divider-line {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.line {
  flex: 1;
  height: 1rpx;
  background: #2a2a3a;
}

.divider-text {
  color: #64748b;
  font-size: 24rpx;
  padding: 0 20rpx;
}

.wx-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #07c160;
  color: #fff;
  border-radius: 24rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
}

.wx-icon {
  font-size: 34rpx;
}

.footer {
  margin-top: 40rpx;
  text-align: center;
}

.footer-text {
  color: #64748b;
  font-size: 26rpx;
}

.footer-link {
  color: #c9a96e;
  font-size: 26rpx;
  margin-left: 8rpx;
}
